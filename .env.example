# Evo Payment UAT Environment
# Copy to .env and fill in your credentials:
#   cp .env.example .env

EVO_MERCHANT_SID=your_sid_here
EVO_SIGN_KEY=your_sign_key_here
EVO_SIGN_TYPE=SHA256
EVO_API_BASE_URL=https://hkg-online-uat.everonet.com
EVO_LINKPAY_BASE_URL=https://hkg-counter-uat.everonet.com

# Test card
TEST_CARD_NUMBER=your_card_number
TEST_CARD_CVC=your_cvc
TEST_CARD_EXPIRY=MMYY

# Vault for tokenization
TEST_VAULT_ID=your_vault_id
